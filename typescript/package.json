{
  "name": "@world-model-mcp/verifier",
  "version": "0.13.0",
  "description": "Standalone reference verifier for the world-model-mcp v0.13+ tamper-evident audit log (TypeScript, byte-identical to the Python reference).",
  "type": "module",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    }
  },
  "files": [
    "dist",
    "src",
    "README.md",
    "LICENSE"
  ],
  "scripts": {
    "build": "tsc",
    "test": "vitest run",
    "typecheck": "tsc --noEmit"
  },
  "keywords": [
    "mcp",
    "compliance",
    "audit",
    "merkle",
    "ed25519",
    "slh-dsa",
    "sphincs",
    "post-quantum",
    "world-model-mcp",
    "verifier"
  ],
  "author": "Saravanan Jaichandaran",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/SaravananJaichandar/world-model-mcp-verifier.git"
  },
  "homepage": "https://github.com/SaravananJaichandar/world-model-mcp-verifier#readme",
  "engines": {
    "node": ">=18.0.0"
  },
  "dependencies": {
    "@noble/curves": "^1.6.0",
    "@noble/hashes": "^1.5.0",
    "@noble/post-quantum": "^0.2.0"
  },
  "devDependencies": {
    "@types/node": "^22.0.0",
    "typescript": "^5.4.0",
    "vitest": "^2.0.0"
  }
}
